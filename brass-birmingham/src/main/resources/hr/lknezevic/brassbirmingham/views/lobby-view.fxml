<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.lknezevic.brassbirmingham.controllers.LobbyController">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="Brass: Birmingham Lite" styleClass="title-label"/>

    <VBox spacing="10" styleClass="panel-card" maxWidth="400">
        <Label text="Player Name" styleClass="section-title"/>
        <TextField fx:id="playerNameField" promptText="Your name"/>
    </VBox>

    <VBox spacing="10" styleClass="panel-card" maxWidth="400">
        <Label text="Quick Start" styleClass="section-title"/>
        <Button fx:id="localBtn" text="Local Game (Hotseat)" onAction="#onLocalGame" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="10" styleClass="panel-card" maxWidth="400">
        <Label text="Online Game" styleClass="section-title"/>
        <HBox spacing="10">
            <TextField fx:id="hostField" promptText="Host IP" prefWidth="200"/>
            <TextField fx:id="portField" promptText="Port" prefWidth="80"/>
        </HBox>
        <HBox spacing="10">
            <Button fx:id="hostBtn" text="Host Game" onAction="#onHostGame"/>
            <TextField fx:id="roomCodeField" promptText="Room code" prefWidth="100"/>
            <Button fx:id="joinBtn" text="Join Game" onAction="#onJoinGame"/>
        </HBox>
        <Label fx:id="roomCodeLabel" text="---"/>
        <Label fx:id="statusLabel" text="Offline"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Scoreboard" onAction="#onScoreboard" styleClass="accent"/>
        <Button text="Watch Replay" onAction="#onWatchReplay"/>
        <Button text="Industry Report" onAction="#onGenerateReport"/>
    </HBox>
</VBox>
