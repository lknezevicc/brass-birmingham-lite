<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT"
      spacing="12"
      styleClass="lobby-header"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.lknezevic.brassbirmingham.controllers.component.HeaderController">

    <padding>
        <Insets bottom="16" left="20" right="20" top="16" />
    </padding>

    <Label fx:id="title" styleClass="lobby-title" text="Title" />
    <Region HBox.hgrow="ALWAYS" />
    <Button fx:id="backButton" text="Button" />
</HBox>
