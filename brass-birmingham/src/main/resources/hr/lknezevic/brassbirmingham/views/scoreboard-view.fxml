<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="lobby-root" stylesheets="@../styles/lobby.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.lknezevic.brassbirmingham.controllers.ScoreboardController">

    <top>
        <fx:include fx:id="headerView" source="components/header-view.fxml" />
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <VBox maxWidth="980" prefWidth="980" spacing="10" styleClass="panel-card" VBox.vgrow="ALWAYS">
                <Label styleClass="section-title" text="Player Ranking" />

                <TextField fx:id="searchField" promptText="Search by username..." />

                <HBox spacing="8">
                    <Label minWidth="80" prefWidth="80" styleClass="muted-text" text="#" />
                    <Label minWidth="280" prefWidth="280" styleClass="muted-text" text="Username" />
                    <Label minWidth="120" prefWidth="120" styleClass="muted-text" text="Played" />
                    <Label minWidth="120" prefWidth="120" styleClass="muted-text" text="Wins" />
                    <Label minWidth="120" prefWidth="120" styleClass="muted-text" text="Losses" />
                    <Label minWidth="120" prefWidth="120" styleClass="muted-text" text="Score (W/L)" />
                </HBox>

                <ListView fx:id="rankingListView" styleClass="scoreboard-list" VBox.vgrow="ALWAYS" />
            </VBox>
        </VBox>
    </center>

</BorderPane>
